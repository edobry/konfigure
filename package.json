{
  "name": "@chainalysis/konfigure",
  "repository": {
    "type": "git",
    "url": "git@github.com:chainalysis/konfigure.git"
  },
  "publishConfig": {
    "registry": "https://fimbulvetr.chainalysis.com/artifactory/api/npm/npm/"
  },
  "version": "0.0.0",
  "author": "Eugene Dobry @edobry",
  "bin": {
    "konfigure": "./bin/run"
  },
  "bugs": "https://github.com/chainalysis/konfigure/issues",
  "devDependencies": {
    "@oclif/dev-cli": "^1.26.0",
    "@types/jest": "^27.0.3",
    "@typescript-eslint/parser": "^5.7.0",
    "conventional-changelog-conventionalcommits": "^4.4.0",
    "eslint": "^8.2.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-unicorn": "^38.0.1",
    "globby": "^10.0.2",
    "jest": "^27.4.5",
    "jest-junit": "^13.0.0",
    "ts-jest": "^27.1.2",
    "ts-node": "^8.10.2",
    "typescript": "^4.4.4"
  },
  "engines": {
    "node": ">=8.0.0"
  },
  "files": [
    "/bin",
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/chainalysis/konfigure",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "konfigure",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "scripts": {
    "posttest": "eslint . --ext .ts --config .eslintrc",
    "test": "jest --passWithNoTests --all",
    "build": "tsc --build tsconfig.json"
  },
  "types": "lib/index.d.ts",
  "dependencies": {
    "@kubernetes/client-node": "^0.16.1",
    "@oclif/command": "^1.8.0",
    "@oclif/config": "^1.17.0",
    "@oclif/plugin-help": "^3.2.3",
    "@types/common-tags": "^1.8.1",
    "@types/js-yaml": "^4.0.3",
    "@types/node": "^16.9.5",
    "@types/tmp": "^0.2.1",
    "chalk": "^4.1.2",
    "cli-highlight": "^2.1.11",
    "common-tags": "^1.8.0",
    "fs-extra": "^10.0.0",
    "js-yaml": "^4.1.0",
    "pino": "^7.0.3",
    "pino-pretty": "^7.1.0",
    "tmp": "^0.2.1",
    "tmp-promise": "^3.0.2",
    "tslib": "^1.14.1",
    "zx": "^4.2.0"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.ts?(x)",
      "**/?(*.)+(spec|test).ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "preset": "ts-jest",
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    }
  }
}
